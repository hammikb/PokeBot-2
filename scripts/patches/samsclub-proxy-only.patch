+def load_proxies() -> list[str]:
+    proxies: list[str] = []
+    for raw in PROXY_FILE.read_text(encoding="utf-8").splitlines():
+        value = raw.strip()
+        if not value or value.startswith("#"):
+            continue
+        if "://" not in value:
+            value = f"http://{value}"
+        proxies.append(value)
+    if not proxies:
+        raise RuntimeError(f"No proxies loaded from {PROXY_FILE}; refusing direct Sam's Club traffic")
+    return proxies
